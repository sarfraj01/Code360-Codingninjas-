    }

    //call dfs toplogical sort util function for all compenets 
    vector<bool> visited(v);
    stack<int> s;
    for(int i = 0; i < v; i++){
        if(!visited[i])
            topoSort(i  , visited , s , adj);        
    }
    
        vector<int> ans;

