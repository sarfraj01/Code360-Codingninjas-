void dfs(int node ,unordered_map<int , bool> &vsiited , unordered_map<int , list<int> > &adj , 
            vector<int> &component ){
        
        //ans ma store
        component.push_back(node);
        //makr visted
        vsiited[node] = true;

        //her component node k liye recursive call
        for(auto i : adj[node]){
            if(!vsiited[i]){
                dfs(i , vsiited , adj , component);
            }
        }   
}

vector<vector<int>> depthFirstSearch(int V, int E, vector<vector<int>> &edges)
{
    //prepare AdjList
    unordered_map<int , list<int> > adj;
    for(int i = 0; i < edges.size(); i++){
        int u = edges[i][0];
        int v = edges[i][1];

        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    vector<vector<int> > ans;
    unordered_map<int , bool> vsiited;

    //for All nodes call DFS , if not visted
    for(int i = 0; i < V; i++){
        if(!vsiited[i]){
            vector<int> component;
            dfs(i , vsiited , adj , component);
            ans.push_back(component);
        }
    }
    return ans;
}

